# Frontend Environment Variables
# Copy this file to .env.local and update with your values

# API Configuration
# For development with Vite proxy: leave empty or use '/api'
# For production: use the full backend URL (e.g., https://api.example.com)
VITE_API_URL=/api

# Application Configuration
VITE_APP_NAME=Gestion Départements
VITE_APP_VERSION=1.0.0

# Debug Mode
VITE_DEBUG=false
